# =============================================================
# Alice in Wellnessland — Environment Variables
# =============================================================
#
# OPTION A — 1Password (production / demo, zero plaintext secrets):
#   Set OP_SERVICE_ACCOUNT_TOKEN and run: npm run dev:secure
#   All other secrets are fetched automatically from 1Password.
#
# OPTION B — Local .env (dev convenience):
#   Fill in the secrets below and run: npm run dev
#
# =============================================================

# 1Password Service Account Token (the ONLY secret needed in CI/CD)
# Get it from: my.1password.com → Settings → Developer → Service Accounts
OP_SERVICE_ACCOUNT_TOKEN=

# Clerk (public key is safe in .env — it's meant to be public)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/tea-party
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/tea-party

# --- Dev-only fallbacks (not needed if using 1Password above) ---
CLERK_SECRET_KEY=
GEMINI_API_KEY=
MONGODB_URI=
